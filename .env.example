# PostgreSQL (local development defaults only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Keycloak (local development defaults only)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8180

# Spring services
DISCOVERY_PORT=8761
API_GATEWAY_PORT=8081
USER_SERVICE_PORT=8101
RESTAURANT_SERVICE_PORT=8102

# Expected JWT audience
KEYCLOAK_AUDIENCE=food-delivery-api

# Restaurant document storage
STORAGE_PROVIDER=CLOUDINARY
STORAGE_MAX_FILE_SIZE=10485760

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_BASE_FOLDER=food-delivery/restaurant-documents

S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PATH_STYLE_ACCESS=false
S3_BASE_FOLDER=restaurant-documents
