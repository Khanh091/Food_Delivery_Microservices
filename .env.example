# PostgreSQL (local development defaults only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Keycloak (local development defaults only)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8180

# Spring services
DISCOVERY_PORT=8761
API_GATEWAY_PORT=8081
USER_SERVICE_PORT=8101

# Expected JWT audience
KEYCLOAK_AUDIENCE=food-delivery-api
